{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["jest", "node"],
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["e2e/**/*", "detox.config.js", "jest.config.js"]
}
