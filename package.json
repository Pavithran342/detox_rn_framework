{
  "name": "detox-react-native-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-ready Detox + Jest automation framework for React Native apps",
  "scripts": {
    "detox:build:android": "detox build --configuration android.emu.debug",
    "detox:test:android": "detox test --configuration android.emu.debug",
    "detox:build:ios": "detox build --configuration ios.sim.debug",
    "detox:test:ios": "detox test --configuration ios.sim.debug",
    "detox:build": "npm run detox:build:android",
    "detox:test": "npm run detox:test:android",
    "test:e2e:smoke": "jest --config e2e/jest.config.js --testNamePattern='smoke' --runInBand",
    "test:e2e:regression": "jest --config e2e/jest.config.js --testNamePattern='regression' --runInBand"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@react-native-community/cli": "^20.2.0",
    "@react-native-community/cli-platform-android": "^20.2.0",
    "@react-native/gradle-plugin": "^0.86.0",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "detox": "^20.0.0",
    "dotenv": "^16.6.0",
    "jest": "^29.7.0",
    "jest-cucumber": "^4.0.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "react-native": "^0.86.0"
  }
}
