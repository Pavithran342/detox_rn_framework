# Valid login credentials for smoke/regression scenarios
VALID_EMAIL=demo@example.com
VALID_PASSWORD=Password123!

# Invalid login credentials used to verify error handling
INVALID_EMAIL=invalid@example.com
INVALID_PASSWORD=WrongPassword123!

# Your app bundle identifier
APP_BUNDLE_ID=com.example.app

# Path to the built Android APK for Detox
ANDROID_APP_PATH=android/app/build/outputs/apk/debug/app-debug.apk

# Path to the built iOS app for Detox
IOS_APP_PATH=ios/build/Build/Products/Debug-iphonesimulator/YourApp.app

# Android emulator name to launch for tests
ANDROID_AVD_NAME=Pixel_5_API_30

# iOS simulator type to launch for tests
IOS_SIMULATOR_TYPE=iPhone 15
